# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local secrets and machine-specific config
.env
.env.*
!.env.example
*.local

# IDE / OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Logs and experiment trackers
*.log
logs/
runs/
wandb/
lightning_logs/

# Hugging Face / model caches
.cache/
hf_cache/
huggingface/

# Raw and processed datasets.
# Keep only lightweight placeholders/docs/templates needed to recreate layout.
data/raw/**
!data/raw/
!data/raw/custom_asr/
!data/raw/custom_asr/README.md
!data/raw/custom_asr/template.example.csv
!data/raw/custom_asr/manifests/
!data/raw/custom_asr/manifests/.gitkeep
data/processed/**
!data/
!data/.gitkeep

# Model outputs and generated predictions/metrics.
# Reports are intentionally not ignored because they are useful deliverables.
outputs/**
!outputs/
!outputs/.gitkeep

# Large model/audio artifacts if they are created outside standard folders
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.onnx
*.mp3
*.wav
*.flac
*.ogg
*.m4a
*.webm

# Notebook checkpoints
.ipynb_checkpoints/
